# Conexión a la instancia Supabase compartida (esquemas econ_raw y econ).
# Usar la conexión DIRECTA o el pooler en modo session (puerto 5432),
# NO el transaction pooler (6543): dbt necesita features de sesión.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require

# URL pública de la documentación dbt en GitHub Pages (se usa en GET / del API).
DBT_DOCS_URL=https://<usuario>.github.io/latam-economic-pulse/

# --- Variables derivadas para dbt (NO editar a mano) ---
# dbt-postgres no acepta una URL: requiere campos discretos. Estas 5 variables
# se derivan de DATABASE_URL con scripts/parse_database_url.py (en CI y en local).
# PGHOST=
# PGPORT=5432
# PGUSER=
# PGPASSWORD=
# PGDATABASE=postgres
